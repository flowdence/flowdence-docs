{
  "name": "flowdence-docs",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "docs:import": "node ./scripts/import-private-docs.mjs --private-root ../flowdence-docs-private --clean",
    "docs:import:dry": "node ./scripts/import-private-docs.mjs --private-root ../flowdence-docs-private --clean --dry-run",
    "docs:validate": "node ./scripts/validate-docs.mjs",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "deploy:ghpages": "gh-pages -d dist --dotfiles",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.37.6",
    "astro": "^5.6.1",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0"
  }
}
